      "name": "13. Security",
      "item": [
        {
          "name": "SQL Injection Attempt",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?category='; DROP TABLE products; --",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [{ "key": "category", "value": "'; DROP TABLE products; --" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Not 500 (SQL injection protected)', () => {",
                  "  pm.expect(pm.response.code).to.not.eql(500);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "XSS Attempt in Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search?q=<script>alert(1)</script>",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [{ "key": "q", "value": "<script>alert(1)</script>" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 422', () => {",
                  "  pm.expect([200, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('No raw script in response', () => {",
                  "  pm.expect(pm.response.text()).to.not.include('<script>alert(1)</script>');",
                  "});"
                ]
