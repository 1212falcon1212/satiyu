                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns JSON', () => pm.response.to.be.json);",
                  "pm.test('Response time < 2s', () => pm.expect(pm.response.responseTime).to.be.below(2000));"
