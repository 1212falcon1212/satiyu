          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns products', () => {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  pm.expect(data).to.be.an('array');",
                  "  pm.expect(data.length).to.be.above(0);",
                  "  if (data[0] && data[0].slug) {",
                  "    pm.collectionVariables.set('productSlug', data[0].slug);",
                  "  }",
                  "});",
                  "pm.test('Product has required fields', () => {",
                  "  const data = (pm.response.json().data || pm.response.json())[0];",
                  "  if (data) {",
                  "    pm.expect(data).to.have.property('name');",
                  "    pm.expect(data).to.have.property('slug');",
                  "    pm.expect(data).to.have.property('price');",
                  "  }",
                  "});",
                  "pm.test('Pagination exists', () => {",
                  "  const json = pm.response.json();",
                  "  if (json.meta || json.total || json.last_page) {",
                  "    pm.expect(true).to.be.true;",
                  "  } else {",
                  "    pm.expect(json.data).to.be.ok;",
                  "  }",
                  "});",
                  "pm.test('Response time < 3s', () => pm.expect(pm.response.responseTime).to.be.below(3000));"
